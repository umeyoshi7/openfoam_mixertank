# Environment variable template for local docker run testing.
#
# Usage:
#   cp .env.example .env
#   # Edit .env and set GCS_BUCKET to your actual bucket name.
#   docker run --env-file .env <IMAGE_URI> /entrypoint_mesh.sh
#
# .env is listed in .gitignore and will not be committed.

# Required
GCS_BUCKET=your-openfoam-bucket

# Optional - mesh job (entrypoint_mesh.sh)
NCORES=4
GCS_MESH_PREFIX=mesh
CASE_NAME=LKHD045

# Optional - solver job (entrypoint_solver.sh)
GCS_RESULT_PREFIX=results
MRF_END_TIME=3000
# GCS_MESH_PATH=   # If omitted, read from gs://<GCS_BUCKET>/mesh/latest.txt
