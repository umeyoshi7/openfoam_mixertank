#!/bin/sh
#------------------------------------------------------------------------------
# Allclean - 生成ファイル全削除スクリプト
# polyMesh, タイムディレクトリ, ログを削除する。
# 0.orig/, 0.mesh/, STL, system/, constant/ 設定ファイルは保持。
#------------------------------------------------------------------------------
cd "${0%/*}" || exit 1

. "${WM_PROJECT_DIR:?}/bin/tools/CleanFunctions"

echo "=== Cleaning LK-1_HD0.45 ==="
cd LK-1_HD0.45
cleanCase
rm -rf constant/polyMesh
rm -rf constant/extendedFeatureEdgeMesh
rm -rf constant/fvMesh
rm -rf processor* log.*
# snappyHexMesh / createBaffles が 0/ を上書きするため 0/ を削除して 0.mesh/ に戻す
rm -rf 0/
cp -r 0.mesh/ 0/
cd ..

echo "=== Cleaning LK-1_HD0.45_MRF ==="
cd LK-1_HD0.45_MRF
cleanCase
rm -f constant/polyMesh
rm -rf processor* log.*
# 0/ を 0.orig/ から復元
rm -rf 0/
[ -d 0.orig ] && cp -r 0.orig/ 0/
cd ..

echo "=== Allclean 完了 ==="

#------------------------------------------------------------------------------
