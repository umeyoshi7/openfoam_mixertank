FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      MRFProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

MRF1
{
    cellZone            rotating;

    active              yes;

    // AMI境界でのMRFソース重複適用を防ぐ
    nonRotatingPatches  (AMI1 AMI2);

    origin              (0 0 0);
    axis                (0 1 0);
    omega               -10.47;
}


