transportModel  powerLaw;

powerLawCoeffs
{
    // k = K/rho = 1.352e-2 / 8020  [m^2/s^n]
    // K гҒӢгӮүеӨүжҸӣ: Ој = 1.5e-3 * u^(-0.433) [mPaВ·s, u=tip speed m/s]
    //   вҶ’ ОіМҮ = 2u/R = 160u [1/s] (R=0.0125m, з„ЎйҷҗеӘ’дҪ“Couetteиҝ‘дјј)
    //   вҶ’ K = 1.5e-3 * 160^0.433 = 1.352e-2 PaВ·s^n
    k       [0 2 -1 0 0 0 0] 1.686e-06;
    n       [0 0  0 0 0 0 0] 0.567;
    nuMin   [0 2 -1 0 0 0 0] 1e-09;
    nuMax   [0 2 -1 0 0 0 0] 1e-04;
}

