        type            symmetry;
    }
    reactor_HD0.45
    {
        type            zeroGradient;
    }
    shaft_HD0.45
    {
        type            zeroGradient;
    }
    impeller_HD0.45
    {
        type            zeroGradient;
    }
    baffle_HD0.45
    {
        type            zeroGradient;
    }
    AMI1
    {
        type            zeroGradient;
    }
    AMI2
    {
        type            zeroGradient;
    }
}


