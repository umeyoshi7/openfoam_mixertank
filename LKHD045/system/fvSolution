FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    Phi
    {
        solver      GAMG;
        smoother    DIC;
        tolerance   1e-06;
        relTol      0.01;
    }

    MeshPhi
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-6;
        relTol          0;
    }
    
    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.01;
    }

    pFinal
    {
        $p;

        tolerance       1e-6;
        relTol          0;
    }

    "pcorr.*"
    {
        $p;

        tolerance       1e-2;
        relTol          0;

    }

    "(U|k|epsilon)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;

        tolerance       1e-6;
        relTol          0.1;
    }

    "(U|k|epsilon)Final"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;

        tolerance       1e-6;
        relTol          0;
    }
}

potentialFlow
{
    nNonOrthogonalCorrectors 10;
    PhiRefPoint   (0 0.06 0.15);
    PhiRefValue  0;
    pRefPoint    (0 0.06 0.15);
    pRefValue   0;
}

PIMPLE
{
    momentumPredictor   yes;
    correctPhi          yes;
    correctMeshPhi      no;
    // 10 → 5: MRF 良質初期値を使うため 5 で十分収束する。
    // 10 outer × NCC stitching(~1 s/iter @8cores) = 10 s/timestep → 遅すぎる。
    nOuterCorrectors    5;
    nCorrectors         4;
    nNonOrthogonalCorrectors 3;
    pRefPoint    (0 0.06 0.15);
    pRefValue   0;

    // kEpsilon の FPE 防止：epsilon/k の下限 + nut/p/U の上限
    // nut 上限: 水 @100 RPM の推定値 ~1.6e-3 を考慮して 0.01 に設定
    // (旧値 1e-3 は Re=470k では過小でクリップが発生していた)
    limitFields
    {
        epsilon     1e-6;
        k           1e-6;
        nut         0.01;
        p           1e6;
        U           100;
    }
}

relaxationFactors
{
    equations
    {
        U           0.7;
        k           0.5;
        // MRF と同じ 0.3 に合わせて dynamicMesh NCC 界面での epsilon 振動を抑制する
        epsilon     0.3;
        ".*"        0.9;
    }
}


