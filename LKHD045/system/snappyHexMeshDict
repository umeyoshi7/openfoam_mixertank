FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Which of the steps to run
castellatedMesh true;
snap            true;
addLayers       false;

geometry
{
    reactor_HD0.45
    {
        file    "reactor_HD0.45.stl";
        type    triSurfaceMesh;
    }

    shaft_HD0.45
    {
        file    "shaft_HD0.45.stl";
        type    triSurfaceMesh;
    }

    impeller_HD0.45
    {
        file    "impeller_HD0.45.stl";
        type    triSurfaceMesh;
    }

    baffle_HD0.45
    {
        file    "baffle_HD0.45.stl";
        type    triSurfaceMesh;
    }

    rotation_HD0.45
    {
        file    "rotation_HD0.45.stl";
        type    triSurfaceMesh;
    }
}


castellatedMeshControls
{
    maxLocalCells 3000000;

    maxGlobalCells 3000000;

    minRefinementCells 2;

    maxLoadUnbalance 0.10;

    nCellsBetweenLevels 3;

    features
    (
        {
           file "reactor_HD0.45.eMesh";
           level 1;
        }
        {
           file "impeller_HD0.45.eMesh";
           level 1;
        }
        {
           file "baffle_HD0.45.eMesh";
           level 1;
        }
        {
           file "shaft_HD0.45.eMesh";
           level 1;
        }
        {
           file "rotation_HD0.45.eMesh";
           level 1;
        }
    );

    refinementSurfaces
    {
        reactor_HD0.45
        {
            level (1 2);
            patchInfo
            {
                type wall;
                inGroups (meshedWalls);
            }
        }

        impeller_HD0.45
        {
            // 本番: (3 4), ローカルテスト: (2 3)
            level (2 3);
            patchInfo
            {
                type wall;
                inGroups (meshedWalls);
            }
        }

        shaft_HD0.45
        {
            // 本番: (3 4), ローカルテスト: (2 3)
            level (2 3);
            patchInfo
            {
                type wall;
                inGroups (meshedWalls);
            }
        }

        baffle_HD0.45
        {
            level (1 2);
            patchInfo
            {
                type wall;
                inGroups (meshedWalls);
            }
        }

        rotation_HD0.45
        {
            level (1 2);
            cellZone rotating;
            faceZone rotating;
            cellZoneInside insidePoint;
            insidePoint (0.05 0.0 0.05);
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
    }

    locationInMesh (0 -0.07 0);

    // false: rotating faceZone に実際の内部面だけを登録する。
    // true にすると境界面や重複面がゾーンに混入し、createNonConformalCouples が
    // AMI 面数 (36k) よりも多い NCC 面数を生成して coverage > 1.0 エラーを引き起こす。
    allowFreeStandingZoneFaces false;
}


snapControls
{
    nSmoothPatch 3;

    tolerance 1.0;

    nSolveIter 300;

    nRelaxIter 10;
    
    nFeatureSnapIter 10;

    implicitFeatureSnap false;

    explicitFeatureSnap true;

    multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;

    expansionRatio 1.0;

    finalLayerThickness 0.3;

    minThickness 0.25;

    layers
    {
        impeller_HD0.45
        {
            nSurfaceLayers      2;
        }
        shaft_HD0.45
        {
            nSurfaceLayers      2;
        }
        rotation_HD0.45
        {
            nSurfaceLayers      2;
        }
    }

    nGrow 0;

    featureAngle 30;

    nRelaxIter 5;

    nSmoothSurfaceNormals 1;

    nSmoothNormals 3;

    nSmoothThickness 10;

    maxFaceThicknessRatio 0.5;

    maxThicknessToMedialRatio 0.3;

    minMedialAxisAngle 90;

    nBufferCellsNoExtrude 0;

    nLayerIter 50;

    nRelaxedIter 20;
}

meshQualityControls
{
    maxNonOrtho 55;

    maxBoundarySkewness 3;
    maxInternalSkewness 3;

    maxConcave 80;

    minVol 1e-13;

    minTetQuality 1e-9;

    minArea 1e-10;

    minTwist 0.05;

    minDeterminant 0.01;

    minFaceWeight 0.03;

    minVolRatio 0.1;

    minTriangleTwist 0.05;

    nSmoothScale 4;
    
    errorReduction 0.85;

    relaxed
    {
        maxNonOrtho 75;
    }
}

mergeTolerance 1e-6;

// ************************************************************************* //
