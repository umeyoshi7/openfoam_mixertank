#!/bin/sh
#------------------------------------------------------------------------------
# Allrun - 全体ワークフロー実行スクリプト（ローカルテスト用）
#
# ワークフロー (OpenFOAM 11 Foundation):
#   Step 1: メッシュ生成 (LK-1_HD0.45)
#             blockMesh → surfaceFeatureExtract → snappyHexMesh
#             → createBaffles → createNonConformalCouples
#   Step 2: MRF 定常計算 (LK-1_HD0.45_MRF)
#             foamRun -solver incompressibleFluid (MRF + NCC 連成)
#   Step 3: フィールドマッピング (MRF → pimpleFoam)
#   Step 4: 非定常計算 (LK-1_HD0.45)
#             foamRun -solver incompressibleFluid (dynamicMesh + NCC)
#
# 前提条件: OpenFOAM 11 環境をソース済みであること
#   source /opt/openfoam11/etc/bashrc  (Ubuntu/WSL)
#
# 使用方法:
#   chmod +x Allrun && ./Allrun
#------------------------------------------------------------------------------
cd "${0%/*}" || exit 1

. "${WM_PROJECT_DIR:?必ず OpenFOAM 11 環境をソースしてから実行してください}/bin/tools/RunFunctions"

# ===========================================================================
# Step 1: メッシュ生成 (LK-1_HD0.45)
# ===========================================================================
echo ""
echo "======================================================"
echo "  Step 1: Mesh Generation (LK-1_HD0.45)"
echo "======================================================"
cd LK-1_HD0.45

runApplication blockMesh
runApplication surfaceFeatureExtract

# CRITICAL: 0/ を 0.mesh/ で置換してから snappyHexMesh を実行する。
# blockMesh は allBoundary+top のみ生成。既存 0/ が reactor/AMI 等を参照すると
# decomposePar (並列実行時) がパッチ不整合でエラーになる。
echo "  Replacing 0/ with 0.mesh/ (pre-snappyHexMesh minimal BCs)..."
rm -rf 0/
cp -r 0.mesh/ 0/

runApplication snappyHexMesh -overwrite

# faceZones 確認 (createBaffles の前提)
if [ ! -f constant/polyMesh/faceZones ]; then
    echo "ERROR: constant/polyMesh/faceZones が存在しません"
    exit 1
fi
echo "  faceZones 確認 OK"

# createBaffles: AMI1/AMI2 を patch 型で作成 (OF11 では cyclicAMI 非サポート)
runApplication createBaffles -overwrite

# createNonConformalCouples: AMI1/AMI2 から nonConformalCyclic 連成を作成
runApplication createNonConformalCouples -overwrite AMI1 AMI2

runApplication checkMesh

# 0/ を MRF 実行用 0.orig/ で上書き (createBaffles/NCC が書き換えた 0/ を修正)
echo "  Restoring 0/ from 0.orig/ for MRF run..."
rm -rf 0/
cp -r 0.orig/ 0/

cd ..

# ===========================================================================
# Step 2: MRF 定常計算 (LK-1_HD0.45_MRF)
# ===========================================================================
echo ""
echo "======================================================"
echo "  Step 2: MRF Steady-State (LK-1_HD0.45_MRF)"
echo "======================================================"
cd LK-1_HD0.45_MRF

# polyMesh シンボリックリンク作成（未作成の場合）
if [ ! -e constant/polyMesh ]; then
    ln -sf ../../LK-1_HD0.45/constant/polyMesh constant/polyMesh
    echo "  Created symlink: constant/polyMesh"
fi

# 0/ を MRF 用 0.orig/ で初期化
echo "  Restoring 0/ from 0.orig/ for MRF..."
rm -rf 0/
cp -r 0.orig/ 0/

runApplication foamRun -solver incompressibleFluid

cd ..

# ===========================================================================
# Step 3: フィールドマッピング (MRF → pimpleFoam 初期値)
# ===========================================================================
echo ""
echo "======================================================"
echo "  Step 3: Map Fields (MRF -> pimpleFoam)"
echo "======================================================"

# pimpleFoam ケースの 0/ を pimpleFoam 用 0.orig/ で初期化
cd LK-1_HD0.45
echo "  Restoring 0/ from 0.orig/ for pimpleFoam..."
rm -rf 0/
cp -r 0.orig/ 0/
cd ..

# MRF ケースから最新タイムを取得してマッピング実行
cd LK-1_HD0.45_MRF
LATEST_MRF_TIME=$(foamListTimes -latestTime 2>/dev/null | tail -1)
if [ -z "${LATEST_MRF_TIME}" ]; then
    echo "ERROR: MRF のタイムディレクトリが見つかりません"
    exit 1
fi
echo "  Mapping from MRF time: ${LATEST_MRF_TIME}"

# -consistent: 同一メッシュのため利用可。境界フィールドもマッピング。
mapFields . -consistent -sourceTime "${LATEST_MRF_TIME}" -case ../LK-1_HD0.45 \
    2>&1 | tee log.mapFields

echo "  mapFields 完了"

cd ..

# ===========================================================================
# Step 4: 非定常計算 (LK-1_HD0.45, dynamicMesh + NCC)
# ===========================================================================
echo ""
echo "======================================================"
echo "  Step 4: Transient pimpleFoam (LK-1_HD0.45)"
echo "======================================================"
cd LK-1_HD0.45

runApplication foamRun -solver incompressibleFluid

cd ..

echo ""
echo "======================================================"
echo "  Allrun 完了"
echo "======================================================"

#------------------------------------------------------------------------------
