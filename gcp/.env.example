# GCP プロジェクト設定
PROJECT_ID=your-gcp-project-id
REGION=asia-northeast1

# GCS バケット
BUCKET=your-openfoam-bucket

# Artifact Registry
AR_REPO=openfoam
IMAGE_NAME=openfoam-ami
IMAGE_TAG=latest
IMAGE_URI=${REGION}-docker.pkg.dev/${PROJECT_ID}/${AR_REPO}/${IMAGE_NAME}:${IMAGE_TAG}

# ジョブ設定 (Vertex AI)
NCORES=4
MACHINE_TYPE=n1-standard-4
TIMEOUT_HOURS=24

# 計算設定
MRF_END_TIME=3000
GCS_RESULT_PREFIX=results
