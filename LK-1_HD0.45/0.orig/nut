FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];


internalField   uniform 0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    top
    {
        type            symmetry;
    }
    reactor_HD0.45
    {
        type            nutkWallFunction;
        value           $internalField;
    }
    shaft_HD0.45
    {
        type            nutkWallFunction;
        value           $internalField;
    }
    impeller_HD0.45
    {
        type            nutkWallFunction;
        value           $internalField;
    }
    baffle_HD0.45
    {
       type             nutkWallFunction;
        value           $internalField;
    }
    AMI1
    {
        type            zeroGradient;
    }
    AMI2
    {
        type            zeroGradient;
    }
}


