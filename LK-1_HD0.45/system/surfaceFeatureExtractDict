// includedAngle:
// Mark edges whose adjacent surface normals are at an angle less
// than includedAngle as features
// - 0  : selects no edges
// - 180: selects all edges

reactor_HD0.45.stl
{
    extractionMethod    extractFromSurface;

    includedAngle       150;

    writeObj            no;
}

