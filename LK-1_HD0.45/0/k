FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// 乱流運動エネルギー [m^2/s^2]
// 推定: u_tip = omega*R = 10.47*0.05 = 0.52 m/s, I=5% → k = 1.5*(I*u_tip)^2 ≈ 1e-3
dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e-3;

boundaryField
{
    reactor_HD0.45
    {
        type            kqRWallFunction;
        value           uniform 1e-3;
    }

    impeller_HD0.45
    {
        type            kqRWallFunction;
        value           uniform 1e-3;
    }

    shaft_HD0.45
    {
        type            kqRWallFunction;
        value           uniform 1e-3;
    }

    baffle_HD0.45
    {
        type            kqRWallFunction;
        value           uniform 1e-3;
    }

    AMI1
    {
        type            cyclicAMI;
        value           uniform 1e-3;
    }

    AMI2
    {
        type            cyclicAMI;
        value           uniform 1e-3;
    }
}

