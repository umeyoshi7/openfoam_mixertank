FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    reactor_HD0.45
    {
        type            noSlip;
    }

    impeller_HD0.45
    {
        // 動的メッシュで回転するインペラ壁面 (rotating zone に属する)
        type            movingWallVelocity;
        value           uniform (0 0 0);
    }

    shaft_HD0.45
    {
        // 動的メッシュで回転するシャフト壁面
        type            movingWallVelocity;
        value           uniform (0 0 0);
    }

    baffle_HD0.45
    {
        type            noSlip;
    }

    AMI1
    {
        type            cyclicAMI;
        value           uniform (0 0 0);
    }

    AMI2
    {
        type            cyclicAMI;
        value           uniform (0 0 0);
    }
}

