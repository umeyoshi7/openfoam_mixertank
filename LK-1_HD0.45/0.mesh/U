FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// メッシュ生成フェーズ専用 BC (snappyHexMesh + createBaffles 用)
// AMI パッチは含めない。createBaffles 後に restore0Dir で 0.orig/ に置換される。

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    top
    {
        type            symmetry;
    }

    reactor_HD0.45
    {
        type            noSlip;
    }

    impeller_HD0.45
    {
        type            noSlip;
    }

    shaft_HD0.45
    {
        type            noSlip;
    }

    baffle_HD0.45
    {
        type            noSlip;
    }
}

