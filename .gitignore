# 環境設定（秘密情報）
.env

# OpenFOAM 計算結果・タイムディレクトリ（0/ はランタイム作業ディレクトリのため除外）
LKHD045/[0-9]*/
LKHD045/[0-9].[0-9]*/
!LKHD045/0.orig/
!LKHD045/0.orig/**
!LKHD045/0.mesh/
!LKHD045/0.mesh/**
LKHD045/processor*/
LKHD045/postProcessing/
LKHD045/log.*
LKHD045/0.backup/
LKHD045MRF/[0-9]*/
!LKHD045MRF/0.orig/
!LKHD045MRF/0.orig/**
LKHD045MRF/processor*/
LKHD045MRF/postProcessing/
LKHD045MRF/log.*

# メッシュ実体（メッシュジョブが生成、大容量）
LKHD045/constant/polyMesh/
LKHD045/constant/fvMesh/
LKHD045/constant/extendedFeatureEdgeMesh/
LKHD045/constant/triSurface/*.eMesh
# MRF ケースの polyMesh はランタイムシンボリックリンクのため追跡しない
LKHD045MRF/constant/polyMesh

# ダウンロードした計算結果
results/

# バックアップファイル・ローカル用ファイル
*.bak
*.foam
LKHD045MRF/mapToTransient.sh
LKHD045/system/mapFieldsDict

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
