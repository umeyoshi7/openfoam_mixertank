FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    Phi
    {
        solver      GAMG;
        smoother    DIC;
        tolerance   1e-06;
        relTol      0.01;
    }

    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.01;
    }

    "(U|k|epsilon)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
    }
}

potentialFlow
{
    nNonOrthogonalCorrectors 10;
    PhiRefPoint   (0 0.06 0.15);
    PhiRefValue   0;
    pRefPoint     (0 0.06 0.15);
    pRefValue     0;
}

SIMPLE
{
    nNonOrthogonalCorrectors 3;
    pRefPoint   (0 0.06 0.15);
    pRefValue   0;
    residualControl
    {
        p               1e-4;
        U               1e-4;
        "(k|epsilon)"   1e-4;
    }

    // transient (LKHD045) 側と同じ上下限を設定する。
    // epsilon/k: 下限のみ（負値・ゼロ除算防止）
    // nut: 上限（乱流粘性爆発 → GAMG 収束不全 → SIGFPE の連鎖を防止）
    // nut 上限: 水 @100 RPM の推定値 ~1.6e-3 を考慮して 0.01 に設定
    // p/U: 上限（NaN 拡散を早期に遮断）
    limitFields
    {
        epsilon     1e-6;
        k           1e-6;
        nut         0.01;
        p           1e6;
        U           100;
    }
}

relaxationFactors
{
    fields
    {
        p               0.3;
    }
    equations
    {
        U               0.7;
        k               0.3;
        epsilon         0.3;
    }
}


