FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    top
    {
        type            symmetry;
    }
    reactor_HD0.45
    {
        type            noSlip;
    }
    shaft_HD0.45
    {
        type            rotatingWallVelocity;
        origin          (0 0 0);
        axis            (0 1 0);
        omega           -10.47;
        value           uniform (0 0 0);
    }
    impeller_HD0.45
    {
        type            rotatingWallVelocity;
        origin          (0 0 0);
        axis            (0 1 0);
        omega           -10.47;
        value           uniform (0 0 0);
    }
    baffle_HD0.45
    {
        type            noSlip;
    }
    AMI1
    {
        type            zeroGradient;
    }
    AMI2
    {
        type            zeroGradient;
    }
    nonConformalCyclic_on_AMI1
    {
        type            nonConformalCyclic;
        value           uniform (0 0 0);
    }
    nonConformalCyclic_on_AMI2
    {
        type            nonConformalCyclic;
        value           uniform (0 0 0);
    }
    nonConformalError_on_AMI1
    {
        type            nonConformalError;
    }
    nonConformalError_on_AMI2
    {
        type            nonConformalError;
    }
}


